# ==============================================================================
# Shield-Core Environment Configuration
# Sao chép file này thành conf/.env và chỉnh sửa các giá trị thực tế
# File này được nạp bởi systemd (EnvironmentFile=-/opt/shield-core/conf/.env)
# ==============================================================================

# ------------------------------------------------------------------------------
# NETWORK INTERFACE
# Tên interface mạng cần bảo vệ (eBPF XDP sẽ attach vào đây)
# Kiểm tra bằng: ip link show
# ------------------------------------------------------------------------------
SHIELD_IFACE=eth0

# ------------------------------------------------------------------------------
# API SERVER
# Địa chỉ listen của Control Plane API (định dạng host:port)
# Mặc định: :9090 (lắng nghe tất cả interfaces, port 9090)
# ------------------------------------------------------------------------------
# SHIELD_LISTEN=:9090

# ------------------------------------------------------------------------------
# CERTIFICATE PATHS (TLS/HTTPS)
# Nếu để trống, shield-ctrl sẽ tự động tạo chứng chỉ tự ký tại:
#   conf/cert.pem và conf/key.pem
# Để dùng cert Let's Encrypt hoặc CA riêng:
# ------------------------------------------------------------------------------
# SHIELD_CERT_PATH=/etc/ssl/certs/shield-core.crt
# SHIELD_KEY_PATH=/etc/ssl/private/shield-core.key

# ------------------------------------------------------------------------------
# BPF FILESYSTEM
# Đường dẫn bpffs để pin BPF maps (mặc định: /sys/fs/bpf/shield_core)
# Thường không cần thay đổi
# ------------------------------------------------------------------------------
# SHIELD_BPF_PIN_PATH=/sys/fs/bpf/shield_core

# ------------------------------------------------------------------------------
# GeoIP DATABASE
# Đường dẫn tới MaxMind GeoLite2 database files
# Download từ: https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# ------------------------------------------------------------------------------
# SHIELD_GEOIP_ASN_DB=data/geoip/GeoLite2-ASN.mmdb
# SHIELD_GEOIP_COUNTRY_DB=data/geoip/GeoLite2-Country.mmdb

# ==============================================================================
# NOTES:
# 1. API Key được cấu hình trong conf/config.json (trường api.api_key)
# 2. Tạo API key an toàn: openssl rand -hex 32
# 3. File conf/.env không nên commit vào git (đã có trong .gitignore)
# ==============================================================================
